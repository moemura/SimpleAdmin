@page "/admin/users"
@using SimpleAdmin.Models
@using SimpleAdmin.Models.DTOs
@using SimpleAdmin.Services.Auth
@inject IAccountService accountService
@inject IMessageService Message
@inject NavigationManager NavigationManager

<PageTitle>Users Management</PageTitle>

<MudPaper Class="pa-4">
    <MudBreadcrumbs Items="_items"></MudBreadcrumbs>

    <MudStack Row Spacing="2" AlignItems="AlignItems.End">
        <MudButton Variant="Variant.Filled" Color="Color.Primary" StartIcon="@Icons.Material.Filled.Add" OnClick="ShowCreateModal">Add new</MudButton>
        <MudTextField T="string" Placeholder="Search users..." Style="width:200px" @bind-Value="_searchText" Immediate="true" OnBlur="@(async () => await OnSearch(_searchText))" />
    </MudStack>

    <MudTable Items="_data" Loading="_loading" Hover="true">
        <HeaderContent>
            <MudTh>Email</MudTh>
            <MudTh>Full Name</MudTh>
            <MudTh>Action</MudTh>
        </HeaderContent>
        <RowTemplate>
            <MudTd>@context.Email</MudTd>
            <MudTd>@context.FullName</MudTd>
            <MudTd>
                <MudFab Size="Size.Small" Color="Color.Primary" StartIcon="@Icons.Material.Filled.Edit" OnClick="() => ShowEditModal(context)" />
                <MudFab Size="Size.Small" Color="Color.Error" StartIcon="@Icons.Material.Filled.Delete" OnClick="() => ShowDeleteModal(context)" />
            </MudTd>
        </RowTemplate>
        <PagerContent>
            <MudTablePager PageSizeOptions="new int[] {5,10,20,50}" />
        </PagerContent>
    </MudTable>

    <MudDialog @bind-Visible="_createModalVisible">
        <TitleContent>
            Create a user
        </TitleContent>
        <DialogContent>
            <EditForm Model="_newUser">
                <MudTextField T="string" Label="Email" @bind-Value="_newUser.Email" />
                <MudTextField T="string" Label="Full Name" @bind-Value="_newUser.FullName" />
                <MudTextField T="string" Label="Password" InputType="InputType.Password" @bind-Value="_newUser.Password" />
                <MudTextField T="string" Label="Confirm Password" InputType="InputType.Password" @bind-Value="_newUser.ConfirmPassword" />
            </EditForm>
        </DialogContent>
        <DialogActions>
            <MudButton Variant="Variant.Filled" Color="Color.Primary" OnClick="OnCreateOk">Create</MudButton>
            <MudButton Variant="Variant.Filled" OnClick="OnCreateCancel">Cancel</MudButton>
        </DialogActions>
    </MudDialog>

</MudPaper>

<MudDialog @bind-Visible="_editModalVisible">
    <TitleContent>
        Edit user
    </TitleContent>
    <DialogContent>
        <EditForm Model="_editUser">
            <MudTextField T="string" Label="Email" @bind-Value="_editUser.Email" />
            <MudTextField T="string" Label="Full Name" @bind-Value="_editUser.FullName" />
        </EditForm>
    </DialogContent>
    <DialogActions>
        <MudButton Variant="Variant.Filled" Color="Color.Primary" OnClick="OnEditOk">Save</MudButton>
        <MudButton Variant="Variant.Filled" OnClick="OnEditCancel">Cancel</MudButton>
    </DialogActions>
</MudDialog>

<MudDialog @bind-Visible="_editModalVisible">
    <TitleContent>
        Delete user
    </TitleContent>
    <DialogContent>
        <EditForm Model="_editUser">
            <MudTextField T="string" Label="Email" @bind-Value="_editUser.Email" />
            <MudTextField T="string" Label="Full Name" @bind-Value="_editUser.FullName" />
        </EditForm>
    </DialogContent>
    <DialogActions>
        <MudButton Variant="Variant.Filled" Color="Color.Secondary" OnClick="OnDeleteOk">Delete</MudButton>
        <MudButton Variant="Variant.Filled" OnClick="OnDeleteCancel">Cancel</MudButton>
    </DialogActions>
</MudDialog>

@code {
    private List<BreadcrumbItem> _items = new List<BreadcrumbItem>
    {
        new BreadcrumbItem("Home", href: "/"),
        new BreadcrumbItem("Users Management", href: "/admin/users")
    };
    private IEnumerable<UserDto> _data = Array.Empty<UserDto>();
    private RegisterDto _newUser = new();
    private UserDto _editUser = new();
    private bool _loading = true;
    private string _searchText = "";
    private bool _createModalVisible = false;
    private bool _editModalVisible = false;
    private bool _deleteModalVisible = false;
    private PaginatedList<UserDto> _paginationData = new();

    private int pageSize = 5;
    private int pageIndex = 1;
    private int totalItems = 0;

    protected override async Task OnInitializedAsync()
    {
        await LoadData();
    }

    private async Task LoadData()
    {
        _loading = true;

        await Task.Delay(100);
        try
        {
            _paginationData = await accountService.GetPaginationAsync(pageIndex, pageSize);
            _data = _paginationData.Data;
            totalItems = _paginationData.ItemCount;
        }
        catch (Exception ex)
        {
            Message.Error($"Error loading data: {ex.Message}");
        }
        finally
        {
            _loading = false;
        }
    }

    private async Task OnSearch(string value)
    {
        _searchText = value;
        pageIndex = 1;
        await LoadData();
    }

    private async Task OnPageSizeChange(int newSize)
    {
        pageSize = newSize;
        pageIndex = 1;
        await LoadData();
    }

    private void ShowCreateModal()
    {
        _newUser = new RegisterDto();
        _createModalVisible = true;
    }

    private void ShowEditModal(UserDto user)
    {
        _editUser = new UserDto
        {
            Id = user.Id,
            Email = user.Email,
            PhoneNumber = user.PhoneNumber,
            FullName = user.FullName
        };
        _editModalVisible = true;
    }

    private void ShowDeleteModal(UserDto user)
    {
        _editUser = new UserDto
        {
            Id = user.Id,
            Email = user.Email,
            PhoneNumber = user.PhoneNumber,
            FullName = user.FullName
        };
        _deleteModalVisible = true;
    }

    private async Task OnCreateOk()
    {
        try
        {
            var result = await accountService.CreateAsync(_newUser);
            if (result.Success)
            {
                Message.Success("User added successfully!");
            }
            else
            {
                Message.Error($"Error adding user: {result.Message}");

            }
            _createModalVisible = false;
            await LoadData();
        }
        catch (Exception ex)
        {
            Message.Error($"Error adding user: {ex.Message}");
        }
    }

    private void OnCreateCancel() => _createModalVisible = false;

    private async Task OnEditOk()
    {
        try
        {
            var result = await accountService.UpdateAsync(_editUser);
            if (result.Success)
            {
                Message.Success("User updated successfully!");
            }
            else
            {
                Message.Error($"Error updating user: {result.Message}");
            }
            _editModalVisible = false;
            await LoadData();
        }
        catch (Exception ex)
        {
            Message.Error($"Error updating user: {ex.Message}");
        }
    }

    private void OnEditCancel() => _editModalVisible = false;

    private async Task OnDeleteOk()
    {
        try
        {
            await accountService.DeleteAsync(_editUser.Id);
            Message.Success("User deleted successfully!");
            _deleteModalVisible = false;
            await LoadData();
        }
        catch (Exception ex)
        {
            Message.Error($"Error deleting user: {ex.Message}");
        }
    }

    private void OnDeleteCancel() => _deleteModalVisible = false;
}